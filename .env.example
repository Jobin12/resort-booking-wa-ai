# --- WhatsApp Cloud API ---
ACCESS_TOKEN=your_whatsapp_access_token
APP_ID=your_whatsapp_app_id
APP_SECRET=your_whatsapp_app_secret
RECIPIENT_WAID=your_recipient_waid
VERSION=v18.0
PHONE_NUMBER_ID=your_phone_number_id
VERIFY_TOKEN=your_verify_token

# WhatsApp number of the resort operator who receives human-escalation summaries.
OPERATOR_WAID=your_operator_whatsapp_number

# --- LLM provider (switch seamlessly between OpenAI and Gemini) ---
# LLM_PROVIDER=openai (default) or LLM_PROVIDER=gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-nano
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.0-flash

# --- PostgreSQL (Docker container on the EC2 host) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=admin
PG_PASS=admin123
PG_DBNAME=car_db

# --- AWS S3 (image presigning) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name
